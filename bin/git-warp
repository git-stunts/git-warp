#!/usr/bin/env node

import { spawnSync } from 'node:child_process';
import { existsSync } from 'node:fs';
import { dirname, resolve } from 'node:path';
import { fileURLToPath } from 'node:url';

const dir = dirname(fileURLToPath(import.meta.url));
const cliCandidates = [
  resolve(dir, '../dist/bin/warp-graph.js'),
  resolve(dir, 'warp-graph.ts'),
];
const cliPath = cliCandidates.find((candidate) => existsSync(candidate));
const args = process.argv.slice(2);

let result;
if (cliPath !== undefined) {
  result = spawnSync(process.execPath, [cliPath, ...args], { stdio: 'inherit' });
} else {
  result = spawnSync('warp-graph', args, { stdio: 'inherit' });
}

if (result.error) {
  process.stderr.write(result.error.message + '\n');
  process.exit(result.error.code || 1);
}

process.exit(result.status ?? 1);
