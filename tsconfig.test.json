{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "test/**/*.ts",
    "src/**/*.ts",
    "src/globals.d.ts",
    "src/domain/warp/_wiredMethods.d.ts"
  ],
  "exclude": [
    "node_modules",
    "test/type-check",
    "test/runtime/deno"
  ]
}
