{
  "name": "@git-stunts/git-warp",
  "version": "18.2.1",
  "imports": {
    "roaring": "npm:roaring@^2.7.0"
  },
  "exports": {
    ".": "./index.ts",
    "./storage": "./storage.ts",
    "./advanced": "./advanced.ts",
    "./diagnostics": "./diagnostics.ts"
  },
  "publish": {
    "include": [
      "index.ts",
      "storage.ts",
      "advanced.ts",
      "diagnostics.ts",
      "src/**/*.ts",
      "src/**/*.d.ts",
      "README.md",
      "CHANGELOG.md",
      "LICENSE",
      "NOTICE"
    ]
  }
}
