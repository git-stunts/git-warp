digraph V17ReleaseBlockers {
  graph [
    rankdir=LR,
    bgcolor="white",
    fontname="Helvetica",
    fontsize=18,
    label="v17.0.0 Release Blocker DAG",
    labelloc=t,
    margin=0.2,
    nodesep=0.45,
    ranksep=0.8
  ];

  node [
    shape=box,
    style="rounded,filled",
    fontname="Helvetica",
    fontsize=10,
    margin="0.10,0.07",
    color="#4b5563",
    penwidth=1.2
  ];

  edge [
    color="#4b5563",
    arrowsize=0.7,
    fontname="Helvetica",
    fontsize=9,
    penwidth=1.1
  ];

  "SPEC_consumer-typecheck-materialize-residue" [
    color="#15803d",
    fillcolor="#bbf7d0",
    label="DONE\nSPEC_consumer-typecheck\nmaterialize residue",
    penwidth=2.4
  ];
