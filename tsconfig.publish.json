{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": false,
    "outDir": "./dist",
    "rootDir": ".",
    "rewriteRelativeImportExtensions": true
  },
  "include": [
    "index.ts",
    "browser.ts",
    "src/**/*.ts",
    "src/globals.d.ts",
    "bin/**/*.ts",
    "scripts/migrations/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "test"
  ]
}
